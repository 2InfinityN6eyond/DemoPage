{
  "name": "page-demo",
  "private": true,
  "type": "module",
  "workspaces": [
    "product-preview"
  ],
  "scripts": {
    "dev": "npm run build:preview && astro dev",
    "start": "npm run dev",
    "build": "npm run build:preview && astro build",
    "build:preview": "node ./scripts/preview-workspace.mjs build",
    "dev:preview": "node ./scripts/preview-workspace.mjs dev",
    "preview": "astro preview",
    "check": "npm run check:preview && NODE_OPTIONS=--max-old-space-size=6144 astro check",
    "check:preview": "node ./scripts/preview-workspace.mjs check"
  },
  "dependencies": {
    "astro": "^6.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "typescript": "^5.0.0"
  }
}
