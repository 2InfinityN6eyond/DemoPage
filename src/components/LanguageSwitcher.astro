---
type LanguageOption = {
  label: string;
  href: string;
  active: boolean;
};

interface Props {
  label: string;
  options: LanguageOption[];
}

const { label, options } = Astro.props;
---

<div class="locale-switch" aria-label={label}>
  {options.map((option) => (
    <a class:list={["locale-chip", { "is-active": option.active }]} href={option.href} lang={option.label.toLowerCase()}>
      {option.label}
    </a>
  ))}
</div>
