---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import type { Locale, SiteDictionary } from "@/i18n/schema";
import { getLanguageOptions, localizedPath } from "@/utils/i18n";

interface Props {
  locale: Locale;
  dictionary: SiteDictionary;
}

const { locale, dictionary } = Astro.props;
const productPath = localizedPath(locale, "product");
const homePath = localizedPath(locale);
const languageOptions = getLanguageOptions(locale);
const productPreviewBase = `${import.meta.env.BASE_URL}product-preview/`;
const previewFeatures = dictionary.hero.previewFeatures;
const previewJsSrc = `${productPreviewBase}product-preview.js${import.meta.env.PROD ? `?v=${Date.now()}` : ""}`;
---

<Header
  locale={locale}
  dictionary={dictionary}
  languageOptions={languageOptions}
  actions={[
    { label: dictionary.nav.product, href: productPath, ghost: true },
    { label: dictionary.nav.talkToSales, href: `${homePath}#contact` }
  ]}
/>

<main id="top">
  <section class="hero section">
    <div class="hero-copy" data-reveal>
      <p class="eyebrow">{dictionary.hero.eyebrow}</p>
      <h1>
        {dictionary.hero.title}
        <span class="headline-shift">{dictionary.hero.titleAccent}</span>
      </h1>
      <p class="hero-lede">{dictionary.hero.lede}</p>

      <div class="hero-actions">
        <a class="button" href={productPath}>{dictionary.hero.primaryCta}</a>
        <a class="button button-ghost" href="#solution">{dictionary.hero.secondaryCta}</a>
      </div>

      <ul class="hero-metrics" aria-label="Key outcomes">
        {dictionary.hero.metrics.map((metric) => (
          <li>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="hero-preview" data-preview-area data-reveal>
      <div class="preview-switcher" data-preview-switcher aria-label="Product feature tabs">
        {previewFeatures.map((feature, index) => (
          <button
            class:list={["preview-switcher-button", { "is-active": index === 0 }]}
            type="button"
            data-preview-feature={feature.id}
            aria-selected={index === 0 ? "true" : "false"}
          >
            <strong>{feature.label}</strong>
          </button>
        ))}
      </div>

      <div class="preview-feature-copy" data-preview-feature-copy>
        {previewFeatures.map((feature, index) => (
          <article class:list={["preview-feature-panel", { "is-active": index === 0 }]} data-preview-feature-panel={feature.id}>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <strong>{feature.label}</strong>
            <p>{feature.summary}</p>
          </article>
        ))}
      </div>

      <div class="product-preview-mount">
        <div data-product-preview data-locale={locale} data-feature={previewFeatures[0].id} data-product-url={productPath}>
        </div>
      </div>
      <script is:inline type="module" src={previewJsSrc}></script>
      <script is:inline>
        const initPreviewSwitchers = () => {
          document.querySelectorAll("[data-preview-switcher]").forEach((switcher) => {
            if (switcher.dataset.previewSwitcherBound === "true") {
              return;
            }

            switcher.dataset.previewSwitcherBound = "true";
            const previewArea = switcher.closest("[data-preview-area]") ?? document;
            const buttons = Array.from(switcher.querySelectorAll("[data-preview-feature]"));
            const panels = Array.from(previewArea.querySelectorAll("[data-preview-feature-panel]"));

            buttons.forEach((button) => {
              button.addEventListener("click", () => {
                const feature = button.dataset.previewFeature;

                buttons.forEach((item) => {
                  const isActive = item === button;
                  item.classList.toggle("is-active", isActive);
                  item.setAttribute("aria-selected", String(isActive));
                });

                panels.forEach((panel) => {
                  panel.classList.toggle("is-active", panel.dataset.previewFeaturePanel === feature);
                });

                window.dispatchEvent(
                  new CustomEvent("logk-preview:set-feature", {
                    detail: { feature }
                  })
                );
              });
            });
          });
        };

        initPreviewSwitchers();
        document.addEventListener("astro:page-load", initPreviewSwitchers);
      </script>
    </div>
  </section>

  <section class="trust-strip section">
    <div class="trust-row">
      {dictionary.trust.map((item) => (
        <span>{item}</span>
      ))}
    </div>
  </section>

  <section id="solution" class="section split-section">
    <div class="section-head" data-reveal>
      <p class="eyebrow">{dictionary.solution.eyebrow}</p>
      <h2>{dictionary.solution.title}</h2>
      <p>{dictionary.solution.description}</p>
    </div>

    <div class="feature-grid">
      {dictionary.solution.cards.map((card) => (
        <article class:list={["feature-card", { "feature-card-tall": card.tall }]} data-reveal>
          <span class="card-index">{card.index}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
          {card.bullets && (
            <ul class="mini-list">
              {card.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>

  <section class="section showcase-section">
    <div class="section-head narrow" data-reveal>
      <p class="eyebrow">{dictionary.showcase.eyebrow}</p>
      <h2>{dictionary.showcase.title}</h2>
      <p>{dictionary.showcase.description}</p>
    </div>

    <div class="showcase" data-showcase>
      <div class="showcase-tabs" data-reveal>
        {dictionary.showcase.tabs.map((tab, index) => (
          <button class:list={["showcase-tab", { "is-active": index === 0 }]} type="button" data-tab={tab.id}>
            {tab.label}
          </button>
        ))}
      </div>

      <div class="showcase-panels" data-reveal>
        {dictionary.showcase.tabs.map((tab, index) => (
          <article class:list={["showcase-panel", { "is-active": index === 0 }]} data-panel={tab.id}>
            <div class="showcase-copy">
              <h3>{tab.title}</h3>
              <p>{tab.body}</p>
            </div>
            <div class="showcase-visual">
              {tab.bullets && (
                <div class="visual-card">
                  <span class="visual-label">{tab.visualLabel}</span>
                  <strong>{tab.visualTitle}</strong>
                  <ul class="mini-list">
                    {tab.bullets.map((bullet) => (
                      <li>{bullet}</li>
                    ))}
                  </ul>
                </div>
              )}
              {tab.stack && (
                <div class="visual-stack">
                  {tab.stack.map((stackLine) => (
                    <div class="stack-card">{stackLine}</div>
                  ))}
                </div>
              )}
              {tab.reviewLines && (
                <div class="review-board">
                  {tab.reviewLines.map((line) => (
                    <div class="review-line">
                      <span class="review-dot"></span>
                      <p>{line}</p>
                    </div>
                  ))}
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="technology" class="section tech-section">
    <div class="section-head" data-reveal>
      <p class="eyebrow">{dictionary.technology.eyebrow}</p>
      <h2>{dictionary.technology.title}</h2>
      <p>{dictionary.technology.description}</p>
    </div>

    <div class="tech-layout">
      <article class="tech-card tech-card-graphic" data-reveal>
        <img src={`${import.meta.env.BASE_URL}assets/tech-lattice.svg`} alt="" aria-hidden="true" />
        <div class="tech-card-copy">
          <span class="eyebrow">{dictionary.technology.graphicEyebrow}</span>
          <h3>{dictionary.technology.graphicTitle}</h3>
          <p>{dictionary.technology.graphicBody}</p>
        </div>
      </article>

      {dictionary.technology.cards.map((card) => (
        <article class="tech-card" data-reveal>
          <span class="card-index">{card.index}</span>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
        </article>
      ))}

      <article class="tech-card stats-card" data-reveal>
        {dictionary.technology.stats.map((stat) => (
          <div class="stat">
            <strong data-count={stat.value}>0</strong>
            <span>{stat.label}</span>
          </div>
        ))}
      </article>
    </div>
  </section>

  <section id="company" class="section company-section">
    <div class="section-head" data-reveal>
      <p class="eyebrow">{dictionary.company.eyebrow}</p>
      <h2>{dictionary.company.title}</h2>
      <p>{dictionary.company.description}</p>
    </div>

    <div class="company-grid">
      {dictionary.company.cards.map((card) => (
        <article class:list={["company-card", { "company-card-wide": card.wide }]} data-reveal>
          <span class="card-index">{card.index}</span>
          {card.title && <h3>{card.title}</h3>}
          {card.body && <p>{card.body}</p>}
          {card.principles?.map((principle) => (
            <div class="principle-row">
              <strong>{principle.title}</strong>
              <span>{principle.body}</span>
            </div>
          ))}
        </article>
      ))}
    </div>
  </section>

  <section id="contact" class="section contact-section" data-reveal>
    <div class="contact-card">
      <div class="contact-copy">
        <p class="eyebrow">{dictionary.contact.eyebrow}</p>
        <h2>{dictionary.contact.title}</h2>
        <p>{dictionary.contact.body}</p>
      </div>

      <div class="contact-actions">
        <a class="button" href="mailto:hello@logk.ai">{dictionary.contact.primaryCta}</a>
        <a class="button button-ghost" href={productPath}>{dictionary.contact.secondaryCta}</a>
      </div>
    </div>
  </section>
</main>

<Footer locale={locale} dictionary={dictionary} />
