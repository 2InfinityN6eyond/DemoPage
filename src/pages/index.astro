---
import { localizedPath } from "@/utils/i18n";

const fallbackPath = localizedPath("en");
const basePath = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0;url=${fallbackPath}`} />
    <script is:inline define:vars={{ basePath }}>
      const base = basePath;
      const fallback = `${base}en/`.replace(/\/{2,}/g, "/");
      const language = navigator.language.toLowerCase();
      const nextPath = language.startsWith("ko") ? `${base}ko/` : fallback;
      window.location.replace(nextPath.replace(/\/{2,}/g, "/"));
    </script>
  </head>
  <body></body>
</html>
