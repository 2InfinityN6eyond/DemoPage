---
import ClientInit from "@/components/ClientInit.astro";
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import type { Locale } from "@/i18n/schema";

interface Props {
  locale: Locale;
  title: string;
  description: string;
}

const { locale, title, description } = Astro.props;
const site = Astro.site;
const hasCanonicalSite = site && site.hostname !== "example.com";
const canonicalUrl = hasCanonicalSite ? new URL(Astro.url.pathname, site).toString() : undefined;
---

<!DOCTYPE html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Instrument+Sans:wght@400;500;600;700&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <ClientRouter />
    <script is:inline>
      const storageKey = "logk-theme";
      const storedTheme = localStorage.getItem(storageKey);
      const resolvedTheme =
        storedTheme === "light" || storedTheme === "dark"
          ? storedTheme
          : window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
      document.documentElement.dataset.theme = resolvedTheme;
    </script>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"></div>
    <div class="page-glow page-glow-left" aria-hidden="true"></div>
    <div class="page-glow page-glow-right" aria-hidden="true"></div>
    <slot />
    <ClientInit />
  </body>
</html>
